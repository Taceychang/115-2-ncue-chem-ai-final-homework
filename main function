                                    ${explanationMarkup}
                                    ${subtasksMarkup}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function updateStatsAndChart(blocks) {
            let totalStudy = 0; 
            let totalExercise = 0; 
            let totalSleep = 0; 
            let totalFree = 0; 

            blocks.forEach(b => {
                let durationHr = (b.end - b.start) / 60;
                if (b.category === 'sleep') totalSleep += durationHr;
                else if (b.category === 'class' || b.category === 'focus') totalStudy += durationHr;
                else if (b.category === 'physical') totalExercise += durationHr;
                else totalFree += durationHr;
            });

            document.getElementById('stat-study').innerText = `${totalStudy.toFixed(1)} 小時`;
            document.getElementById('stat-exercise').innerText = `${totalExercise.toFixed(1)} 小時`;
            document.getElementById('stat-sleep').innerText = `${totalSleep.toFixed(1)} 小時`;
            document.getElementById('stat-free').innerText = `${totalFree.toFixed(1)} 小時`;

            drawTimeChart(totalSleep, totalStudy, totalExercise, totalFree);
        }

        function initChart() {
            drawTimeChart(8, 6, 1.5, 8.5);
        }

        function drawTimeChart(sleep, study, exercise, free) {
            const ctx = document.getElementById('timeChart').getContext('2d');
            
            if (chartInstance) chartInstance.destroy();

            chartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['🛌 睡眠', '🎓 學習/課程', '🏃 運動', '🍵 留白與生活'],
                    datasets: [{
                        data: [sleep, study, exercise, free],
                        backgroundColor: ['#94a3b8', '#6366f1', '#10b981', '#cbd5e1'],
                        borderColor: '#ffffff',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    cutout: '65%'
                }
            });
        }

        function copyAsText() {
            const timeline = document.getElementById('schedule-timeline');
            const dateStr = document.getElementById('schedule-date').value || "今日";
            const dateObj = new Date(dateStr);
            const dayName = dayNameMap[dateObj.getDay()] || "今日";

            if (timeline.classList.contains('hidden')) {
                openModal("提示", "目前無日程可複製。請先點擊智慧排程生成作息！");
                return;
            }

            let text = `📅 大學生活・我的 [${dateStr} ${dayName}] 24H 智能作息表\n================================\n`;
            computedScheduleForAI.forEach(b => {
                const duration = b.end - b.start;
                text += `⏰ [24H] ${minToTime(b.start)} - ${minToTime(b.end)} (${duration}m) | [${b.category.toUpperCase()}]\n📌 ${b.title}\n`;
                if (b.explanation) {
                    text += `💡 理由/建議：${b.explanation}\n`;
                }
                text += `--------------------------------\n`;
            });
            text += `\n✨ 由 [智編一日] 智能作息規劃器自動生成`;

            const tempInput = document.createElement("textarea");
            tempInput.value = text;
            document.body.appendChild(tempInput);
            tempInput.select();
            
            try {
                const success = document.execCommand('copy');
                if (success) showToast("📋 成功將緊湊作息排程複製至剪貼簿！");
            } catch(e) {
                openModal("手動複製", text);
            }
            document.body.removeChild(tempInput);
        }

        function openModal(title, body) {
            document.getElementById('modal-title').innerText = title;
            document.getElementById('modal-body').innerText = body;
            document.getElementById('info-modal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('info-modal').classList.add('hidden');
        }

        function showToast(text) {
            const toast = document.getElementById('toast-message');
            const toastText = document.getElementById('toast-text');
            toastText.innerText = text;
            toast.classList.remove('hidden');
            setTimeout(() => { hideToast(); }, 4500);
        }

        function hideToast() {
            document.getElementById('toast-message').classList.add('hidden');
        }
    </script>
</body>
</html>
