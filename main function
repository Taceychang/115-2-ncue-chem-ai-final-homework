                            <div class="mt-2.5 bg-indigo-50/60 text-indigo-950 text-[11px] leading-relaxed p-2.5 rounded-xl border border-indigo-100/40 font-sans">
                                <span class="font-extrabold text-brand-700"><i class="fa-solid fa-lightbulb text-amber-500"></i> 排程生理理由：</span>
                                <span class="text-slate-700">${b.explanation}</span>
                            </div>
                        `;
                    }
                }

                let subtasksMarkup = '';
                if (b.subtasks && b.subtasks.length > 0) {
                    subtasksMarkup = `
                        <div class="mt-3 bg-white/70 p-2.5 rounded-lg border border-slate-200/50 font-sans">
                            <p class="text-[9px] font-extrabold text-slate-400 uppercase tracking-widest mb-1.5">🎯 子任務任務清單：</p>
